PORT=3004
SESSION_SECRET=change-me-to-a-long-random-string
GEMINI_API_KEY=
# Optional fallback key — used automatically when the primary key returns
# a 429 / RESOURCE_EXHAUSTED error. Pattern: free-tier project as primary,
# paid project as fallback. Leave blank to disable fallback.
GEMINI_API_KEY_FALLBACK=
# Optional — seconds the primary key is skipped after it 429s (default 60).
# Prevents wasted round-trips while quota is exhausted.
GEMINI_PRIMARY_COOLDOWN_SECONDS=60
# Optional — default is gemini-3.1-flash-lite-preview ($0.25/$1.50 per 1M
# tokens, good quality/price). Alternatives:
#   gemini-2.5-flash-lite        $0.10 / $0.40  (cheaper, slightly less accurate)
#   gemini-2.5-flash             $0.30 / $2.50
#   gemini-3-flash-preview       $0.50 / $3.00  (top quality)
GEMINI_VISION_MODEL=gemini-3.1-flash-lite-preview
# Chat model for the AI Assistant page. Can be the same as the vision
# model. Swap to gemini-2.5-flash if responses feel underpowered.
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# In prod: https://your.domain/tea/api/auth/google/callback
# In dev:  http://localhost:3004/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3004/api/auth/google/callback
